# Get a client_id (and create a "Public Client") at https://dashboard.yoto.dev/
# Public client = no client_secret needed (device flow).
YOTO_CLIENT_ID=
YOTO_AUTH_BASE=https://login.yotoplay.com
YOTO_API_BASE=https://api.yotoplay.com
YOTO_AUDIENCE=https://api.yotoplay.com
# Scopes needed for browse + control:
#   family:library:view       - read library
#   family:devices:view       - list players
#   family:devices:control    - send commands
#   family:device-status:view - read now-playing / status
#   user:content:view         - read MYO cards
#   offline_access            - get a refresh_token
YOTO_SCOPES=offline_access family:library:view family:devices:view family:devices:control family:device-status:view user:content:view

# Where tokens & caches live
DATA_DIR=./data
TOKENS_DIR=./tokens

# Default player to send commands to if more than one is on the account.
# Leave blank to use the first one returned by /devices.
DEFAULT_DEVICE_ID=

# Server
HOST=0.0.0.0
PORT=8000
